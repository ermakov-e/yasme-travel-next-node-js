# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password

# ─── Backend (apps/backend) ───────────────────────────────────
DATABASE_URL=postgresql://yasme:changeme_strong_password@localhost:5432/yasme_travel
JWT_SECRET=                         # openssl rand -hex 32
JWT_EXPIRES_IN=7d

# Yandex OAuth2
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback

# Yandex Object Storage (S3-compatible)
YOS_ACCESS_KEY_ID=
YOS_SECRET_ACCESS_KEY=
YOS_BUCKET_NAME=yasme-travel-photos
YOS_REGION=ru-central1
YOS_ENDPOINT=https://storage.yandexcloud.net

# CORS
CORS_ORIGIN=http://localhost:3000

# Server
PORT=3001
NODE_ENV=development

# ─── Frontend (apps/frontend) ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_YOS_PUBLIC_BASE_URL=https://yasme-travel-photos.storage.yandexcloud.net
